# URI kết nối MongoDB (ví dụ MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.mongodb.net/ielts_listening_review?retryWrites=true&w=majority

# Khóa bí mật bảo vệ API Cron (tự tạo một chuỗi ngẫu nhiên, cấu hình trên Vercel)
CRON_SECRET=my_super_secret_cron_key

# Gmail dùng để gửi mail nhắc ôn thẻ (tạo App Password tại https://myaccount.google.com/apppasswords)
GMAIL_USER=ban@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Địa chỉ nhận mail nhắc (có thể trùng GMAIL_USER)
MAIL_TO=ban@gmail.com
